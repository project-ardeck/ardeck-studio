{
  "build": {
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ]
  },
  "productName": "ardeck",
  "mainBinaryName": "ardeck",
  "version": "0.2.0",
  "identifier": "com.ardeck.studio",
  "plugins": {},
  "app": {
    "windows": [
      {
        "title": "ardeck",
        "minHeight": 600,
        "minWidth": 800,
        "decorations": false,
        "resizable": true,
        "visible": false,
        "useHttpsScheme": true
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["default"]
    }
  }
}